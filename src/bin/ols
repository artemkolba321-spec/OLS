#!/usr/bin/env bash
# Open Linux Shell (OLS)

set -euo pipefail
IFS=$'\n\t'

source "$HOME/.local/share/OLS/lib/env.sh"

# ===== Help =====
show_help() {
    cat <<'EOF'
Open Linux Shell (OLS)

usage:
    ols              - start interactive shell
    ols --help       - show this help
    ols --version    - show OLS version
    ols <File>.ols   - execute OLS script
    ols doctor       - run diagnostics
    ols update       - update OLS
    ols clean        - clear cache

interactive:
    help             - show this help
    exit             - exit OLS
    PATH             - show PATH or OLS tree
    doctor           - run diagnostics 
    <command> [args] - run system or plugin command
EOF
}
ols_update() {

    mode="update"
    branch="lts"

    # ===== Parse options =====
    for arg in "$@"; do
        case "$arg" in
            --check) mode="check" ;;
            --force) mode="force" ;;
            --nolts) branch="main" ;;
            *) ;;
        esac
    done

    # ===== Current version/ref =====
    CURRENT=$(cat "$OLS_DIR/.version" 2>/dev/null || echo "0.0.0")
    REPO="artemkolba321-spec/OLS"
    STATE_FILE="$HOME/.local/share/ols/state.json"
    mkdir -p "$(dirname "$STATE_FILE")"

    # ===== Determine latest ref =====
    if [[ "$branch" == "lts" ]]; then
        LATEST_TAG=$(curl -s "https://api.github.com/repos/$REPO/tags" | \
                     grep '"name":' | grep 'lts' | head -n1 | sed -E 's/.*"([^"]+)".*/\1/')
        [[ -z "$LATEST_TAG" ]] && { echo "Cannot fetch latest LTS."; return 1; }
        REF="$LATEST_TAG"
    else
        LATEST_SHA=$(curl -s "https://api.github.com/repos/$REPO/commits/main" | \
                     grep '"sha":' | head -n1 | sed -E 's/.*"([^"]+)".*/\1/')
        [[ -z "$LATEST_SHA" ]] && { echo "Cannot fetch latest main commit."; return 1; }
        REF="$LATEST_SHA"
    fi

    CURRENT_REF=$(jq -r '.last_ref // ""' "$STATE_FILE" 2>/dev/null || echo "")

    # ===== Check only mode =====
    if [[ "$mode" == "check" ]]; then
        if [[ "$REF" != "$CURRENT_REF" ]]; then
            echo "Update available: $REF (current: $CURRENT_REF)"
        else
            echo "Already up to date: $CURRENT_REF"
        fi
        return 0
    fi

    # ===== Already up to date =====
    if [[ "$mode" == "update" && "$REF" == "$CURRENT_REF" ]]; then
        echo "Already up to date: $CURRENT_REF"
        return 0
    fi

    # ===== Prepare temp dirs =====
    TMP_BASE="$HOME/.cache/OLS/pkg"
    TMP_DIR="$TMP_BASE/OLS-$REF"
    ARCHIVE="$TMP_DIR/ols.tar.gz"
    ARCHIVE_DIR="$TMP_BASE/ols_unpack"

    mkdir -p "$TMP_DIR" "$ARCHIVE_DIR"

    # ===== Download archive =====
    echo "Downloading OLS ($branch) $REF..."
    if [[ "$branch" == "lts" ]]; then
        curl -L "https://github.com/$REPO/archive/refs/tags/$REF.tar.gz" -o "$ARCHIVE" \
            || { echo "Download failed"; rm -rf "$TMP_DIR"; return 1; }
    else
        curl -L "https://github.com/$REPO/archive/refs/heads/main.tar.gz" -o "$ARCHIVE" \
            || { echo "Download failed"; rm -rf "$TMP_DIR"; return 1; }
    fi

    # ===== Extract archive =====
    tar -xzf "$ARCHIVE" -C "$ARCHIVE_DIR"|| { echo "Extraction failed"; rm -rf "$TMP_DIR"; return 1; }

    TAR_DIR=$(find "$ARCHIVE_DIR" -mindepth 1 -maxdepth 1 -type d | head -n1)

    # ===== Install files =====
    echo "Installing..."
    cd "$TAR_DIR" || return 1
    make reinstall

    # ===== Update state =====
    echo "{\"last_check\":$(date +%s),\"last_ref\":\"$REF\"}" > "$STATE_FILE"

    echo "OLS updated to $REF"

}

ols_doctor() {
    set -u

    echo "OLS Doctor report"
    echo "------------------"

    OLS_DIR="${OLS_DIR:-$HOME/.local/share/OLS}"
    BIN_DIR="${BIN_DIR:-$OLS_DIR/bin}"
    LOG_FILE="${LOG_FILE:-$OLS_DIR/logs.log}"

    SYSTEM_DIRS=("$OLS_DIR" "$BIN_DIR")
    SYSTEM_FILES=("$LOG_FILE")
    DEPENDENCIES=(git wget bash tree realpath curl lua jq make openssl)
    PY_DEPS=(textual)

    for dir in "${SYSTEM_DIRS[@]}"; do
        [[ -d "$dir" ]] && echo "[OK] Directory: $dir" || echo "[FAIL] Directory missing: $dir"
    done

    for file in "${SYSTEM_FILES[@]}"; do
        [[ -f "$file" ]] && echo "[OK] File: $file" || echo "[WARN] File missing: $file"
    done

    for cmd in "${DEPENDENCIES[@]}"; do
        command -v "$cmd" >/dev/null 2>&1 && echo "[OK] Command: $cmd" || echo "[FAIL] Command missing: $cmd"
    done
    
    for py in "${PY_DEPS[@]}"; do
        python3 -c "import $py" >/dev/null 2>&1 && echo "[OK] python module: $py" || echo "[FAIL] python module not found: $py"
    done
}

# ===== Interactive shell =====
interactive_shell() {
    info "Interactive shell started"
    echo "Welcome to OLS! (help — show help, exit — quit)"

    while true; do
        OLD_IFS="$IFS"
        IFS=' ' read -rp "ols> " -a input_words || break
        IFS="$OLD_IFS"
        cmd="${input_words[0]-}"
        args=("${input_words[@]:1}")

        case "$cmd" in
            exit)
                info "Shell exited"
                echo "Goodbye!"
                break
                ;;
            help)
                show_help
                ;;
            PATH)
                [[ "${args[0]-}" == "OLS" ]] && tree "$OLS_DIR" || echo "$PATH"
                ;;
            doctor)
                ols_doctor
                ;;
            run)
                if [[ -z "${args[0]-}" ]]; then
                    echo "Usage: run <module> [args...]"
                    continue
                fi
                MODULE="${args[0]}"
                MODULE_ARGS=("${args[@]:1}")
                FOUND=0
                for f in "$OLS_DIR/sbin/module"/*.lua; do
                    [[ "$(basename "$f" .lua)" == "$MODULE" ]] && lua "$f" "${MODULE_ARGS[@]}" && FOUND=1 && break
                done
                [[ $FOUND -eq 0 ]] && warn "Module not found: $MODULE"
                ;;
            *)
                if [[ -f "$OLS_DIR/plugins/$cmd/plugin.lua" ]]; then
                    info "Running plugin: $cmd ${args[*]-}"
                    lua "$OLS_DIR/plugins/$cmd/plugin.lua" "${args[@]}"
                    info "Plugin $cmd finished"
                elif command -v "$cmd" >/dev/null 2>&1; then
                    "$cmd" "${args[@]-}"
                else
                    ee "Unknown command: $cmd"
                fi
                ;;
        esac
    done
}
if [[ "${1-}" == "--help" ]]; then
    show_help
    exit 0
fi

# ===== Main =====
case "${1-}" in
    --version)
        echo "$OLS_VERSION"
        ;;
    --LOG_LEVEL=*)
        LOG_LEVEL="${1#*=}"
        export LOG_LEVEL
        echo "$LOG_LEVEL" > "$OLS_DIR/.loglevel"
        shift
        ;;
        
    clean)
        mkdir -p ~/.cache/OLS
        rm -rf ~/.cache/OLS/*
        ;;
    -e)
        shift
        bash -c "$@"
        ;;
    doctor)
        ols_doctor
        ;;
    update)
        shift
        ols_update "${@-}"
        ;;
    
    ""|" ")
        interactive_shell
        ;;
    *.ols)
        FILE="$1"
        shift || true

        # Normalize path
        if [[ "$FILE" != /* ]]; then
            FILE="$(realpath "$FILE")"
        fi

        [[ ! -f "$FILE" ]] && warn "File not found: $FILE"

        bash "$FILE" "$@"
        ;;
    *)
        ee "Unknown command: $1"
        ;;
esac

