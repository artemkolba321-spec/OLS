#!/usr/bin/env bash
# Open Linux Shell (OLS)

set -u
IFS=$'\n\t'

source "$HOME/.local/share/OLS/lib/env.sh"

# ===== Help =====
show_help() {
    cat <<'EOF'
Open Linux Shell (OLS)

usage:
    ols              - start interactive shell
    ols --help       - show this help
    ols doctor       - run diagnostics

interactive:
    help             - show this help
    exit             - exit OLS
    PATH             - show PATH or OLS tree
    doctor           - run diagnostics
    <command> [args] - run system command
EOF
}
ols_update() {

    mode="update"
    branch="lts"

    # ===== Parse options =====
    for arg in "$@"; do
        case "$arg" in
            --check) mode="check" ;;
            --force) mode="force" ;;
            --nolts) branch="main" ;;
            *) ;;
        esac
    done

    # ===== Current version/ref =====
    CURRENT=$(cat "$OLS_DIR/.version" 2>/dev/null || echo "0.0.0")
    REPO="artemkolba321-spec/OLS"
    STATE_FILE="$HOME/.local/share/ols/state.json"
    mkdir -p "$(dirname "$STATE_FILE")"

    # ===== Determine latest ref =====
    if [[ "$branch" == "lts" ]]; then
        LATEST_TAG=$(curl -s "https://api.github.com/repos/$REPO/tags" | \
                     grep '"name":' | grep 'lts' | head -n1 | sed -E 's/.*"([^"]+)".*/\1/')
        [[ -z "$LATEST_TAG" ]] && { echo "Cannot fetch latest LTS."; return 1; }
        REF="$LATEST_TAG"
    else
        LATEST_SHA=$(curl -s "https://api.github.com/repos/$REPO/commits/main" | \
                     grep '"sha":' | head -n1 | sed -E 's/.*"([^"]+)".*/\1/')
        [[ -z "$LATEST_SHA" ]] && { echo "Cannot fetch latest main commit."; return 1; }
        REF="$LATEST_SHA"
    fi

    CURRENT_REF=$(jq -r '.last_ref // ""' "$STATE_FILE" 2>/dev/null || echo "")

    # ===== Check only mode =====
    if [[ "$mode" == "check" ]]; then
        if [[ "$REF" != "$CURRENT_REF" ]]; then
            echo "Update available: $REF (current: $CURRENT_REF)"
        else
            echo "Already up to date: $CURRENT_REF"
        fi
        return 0
    fi

    # ===== Already up to date =====
    if [[ "$mode" == "update" && "$REF" == "$CURRENT_REF" ]]; then
        echo "Already up to date: $CURRENT_REF"
        return 0
    fi

    # ===== Prepare temp dirs =====
    TMP_BASE="$HOME/.cache/OLS/pkg"
    TMP_DIR="$TMP_BASE/OLS-$REF"
    ARCHIVE="$TMP_DIR/ols.tar.gz"
    ARCHIVE_DIR="$TMP_BASE/ols_unpack"

    mkdir -p "$TMP_DIR" "$ARCHIVE_DIR"

    # ===== Download archive =====
    echo "Downloading OLS ($branch) $REF..."
    if [[ "$branch" == "lts" ]]; then
        curl -L "https://github.com/$REPO/archive/refs/tags/$REF.tar.gz" -o "$ARCHIVE" \
            || { echo "Download failed"; rm -rf "$TMP_DIR"; return 1; }
    else
        curl -L "https://github.com/$REPO/archive/refs/heads/main.tar.gz" -o "$ARCHIVE" \
            || { echo "Download failed"; rm -rf "$TMP_DIR"; return 1; }
    fi

    # ===== Extract archive =====
    tar -xzf "$ARCHIVE" -C "$ARCHIVE_DIR" || { echo "Extraction failed"; rm -rf "$TMP_DIR"; return 1; }

    if [[ "$branch" == "lts" ]]; then
        TAR_DIR="$ARCHIVE_DIR/OLS-$REF"
    else
        TAR_DIR="$ARCHIVE_DIR/OLS-main"
    fi

    # ===== Install files =====
    echo "Installing..."
    mkdir -p "$OLS_DIR/bin" "$OLS_DIR/lib" "$OLS_DIR/sbin" "$OLS_DIR/assets"

    [[ -d "$TAR_DIR/src/bin" ]] && cp -r "$TAR_DIR/src/bin/"* "$OLS_DIR/bin/"
    [[ -d "$TAR_DIR/src/lib" ]] && cp -r "$TAR_DIR/src/lib/"* "$OLS_DIR/lib/"
    [[ -d "$TAR_DIR/assets" ]] && cp -r "$TAR_DIR/assets/"* "$OLS_DIR/assets/"
    [[ -d "$TAR_DIR/src/sbin" ]] && cp -r "$TAR_DIR/src/sbin/"* "$OLS_DIR/sbin/"

    chmod 755 "$OLS_DIR/bin/"* "$OLS_DIR/sbin/"* 2>/dev/null || true
    chmod -R 700 "$OLS_DIR/lib" 2>/dev/null || true

    # ===== Update state =====
    echo "{\"last_check\":$(date +%s),\"last_ref\":\"$REF\"}" > "$STATE_FILE"

    echo "OLS updated to $REF"

}

# ===== Doctor =====
ols_doctor() {
    echo "OLS Doctor report"
    echo "------------------"

    # ===== Counters =====
    ok_count=0
    warn_count=0
    fail_count=0

    # ===== Checked paths to avoid duplicates =====
    declare -A checked

    # ===== Universal check function =====
    check() {
        local type="$1"
        local target="$2"

        # empty target
        [[ -z "$target" ]] && { echo "[WARN] Empty target for type: $type"; ((warn_count++)); return; }

        # normalize path for dirs/files
        if [[ "$type" == "dir" || "$type" == "file" ]]; then
            target=$(realpath -m "$target")
        fi

        # skip if already checked
        [[ -n "${checked[$target]+_}" ]] && return
        checked[$target]=1

        # ===== Check by type =====
        case "$type" in
            dir)
                if [[ -d "$target" ]]; then
                    echo "[OK]     Directory: $target"
                    ((ok_count++))
                else
                    echo "[FAIL]   Directory missing: $target"
                    ((fail_count++))
                fi
                ;;
            file)
                if [[ -f "$target" ]]; then
                    echo "[OK]     File: $target"
                    ((ok_count++))
                else
                    echo "[FAIL]   File missing: $target"
                    ((fail_count++))
                fi
                ;;
            cmd)
                if command -v "$target" >/dev/null 2>&1; then
                    echo "[OK]     Command: $target"
                    ((ok_count++))
                else
                    echo "[FAIL]   Command missing: $target"
                    ((fail_count++))
                fi
                ;;
            *)
                echo "[WARN] Unknown check type: $type"
                ((warn_count++))
                ;;
        esac
    }

    # ===== Paths & dependencies =====
    OLS_DIR="${OLS_DIR:-$HOME/OLS}"
    BIN_DIR="${BIN_DIR:-$OLS_DIR/bin}"
    LOG_FILE="${LOG_FILE:-$OLS_DIR/logs.log}"

    SYSTEM_DIRS=("$OLS_DIR" "$BIN_DIR")
    SYSTEM_FILES=("$LOG_FILE")
    DEPENDENCIES=(git wget bash tree realpath curl lua jq openssl) 

    # ===== Check directories =====
    for dir in "${SYSTEM_DIRS[@]}"; do
        check dir "$dir"
    done

    # ===== Check files =====
    for file in "${SYSTEM_FILES[@]}"; do
        check file "$file"
    done

    # ===== Check commands =====
    for cmd in "${DEPENDENCIES[@]}"; do
        check cmd "$cmd"
    done

    # ===== Summary =====
    echo
    echo "Summary:"
    echo "  OK: $ok_count"
    echo "  WARN: $warn_count"
    echo "  FAIL: $fail_count"
}

# ===== Interactive shell =====
interactive_shell() {
    info "Interactive shell started"
    echo "Welcome to OLS! (help — show help, exit — quit)"

    while true; do
        OLD_IFS="$IFS"
        IFS=' ' read -rp "ols> " -a input_words || break
        IFS="$OLD_IFS"

        cmd="${input_words[0]-}"
        args=("${input_words[@]:1}")
        case "$cmd" in
            exit)
                info "Shell exited"
                echo "Goodbye!"
                break
                ;;
            help)
                show_help
                ;;
            PATH)
                case "${args[0]-}" in
                    OLS)
                        tree "$OLS_DIR"
                        ;;
                    *)
                        echo "$PATH"
                        ;;
                esac
                ;;
            doctor)
                ols_doctor
                ;;
            run)
                if [[ -z "${args[0]-}" ]]; then
                    echo "Usage: run
                     <module> [args...]"
                    continue
                fi

                MODULE_NAME="${args[0]}"
                MODULE_ARGS=("${args[@]:1}")
                MODULE_DIR="$OLS_DIR/sbin/module"
                FOUND=0

                for f in "$MODULE_DIR"/*.lua; do
                    filename=$(basename "$f" .lua)
                    if [[ "$filename" == "$MODULE_NAME" ]]; then
                        lua "$f" "${MODULE_ARGS[@]}"
                        FOUND=1
                        break
                    fi
                done

                if [[ $FOUND -eq 0 ]]; then
                    echo "Unknown module: $MODULE_NAME"
                fi
                ;;
                *)
                PLUGIN_DIR="$OLS_DIR/plugins/$cmd"
                PLUGIN_MAIN="$PLUGIN_DIR/plugin.lua"

                if [[ -f "$PLUGIN_MAIN" ]]; then
                      lua "$PLUGIN_MAIN" "${args[@]}"
                    continue
                fi
                
                # If not a plugin, try system command
                if command -v "$cmd" >/dev/null 2>&1; then
                    "$cmd" "${args[@]-}"
                    continue
                fi

                echo "Unknown command: $cmd"
                ee "Unknown command: $cmd"
                ;;
        esac
    done
}


# ===== Main =====
case "${1-}" in
    --help)
        show_help
        ;;
    --version)
        echo "$OLS_VERSION"
        ;;
    clean)
        mkdir -p ~/.cache/OLS
        rm -rf ~/.cache/OLS/*
        : > "$LOG_FILE"
        ;;
    -e)
        shift
        eval "${@:2}"
        ;;
    doctor)
        ols_doctor
        ;;
    update)
        shift
        ols_update "${@-}"
        ;;
    "")
        interactive_shell
        ;;
    *.ols)
        FILE="$1"
        shift || true

        # Normalize path
        if [[ "$FILE" != /* ]]; then
            FILE="$(realpath "$FILE")"
        fi

        [[ ! -f "$FILE" ]] && warn "File not found: $FILE"

        bash "$FILE" "$@"
        ;;
    *)
        ee "Unknown command: $1"
        ;;
esac

