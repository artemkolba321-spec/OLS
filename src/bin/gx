#!/usr/bin/env bash
# OLS command: gx

set -euo pipefail
IFS=$'\n\t'

source "$HOME/.local/share/OLS/lib/env.sh"

# ===== Help =====
show_help() {
    cat <<'EOF'
gx - Git exec (clone wrapper)

usage:
    gx <user>/<repo>
    gx <HTTPS>
    gx <SSH>

description:
    Clones a GitHub repository. DOES NOT change directory.
EOF
}
if [[ $# -eq 0 || "$1" == "--help" ]]; then
    show_help
    exit 0
fi

command -v git >/dev/null 2>&1 || warn "Git not found"

# ===== Main =====
repo="$1"

# Determine URL and directory name
if [[ "$repo" =~ ^https://github.com/ ]]; then
    url="$repo"
    dir="$(basename "$repo" .git)"
elif [[ "$repo" =~ ^git@github.com: ]]; then
    url="$repo"
    dir="$(basename "$repo" .git)"
else
    url="https://github.com/$repo.git"
    dir="$(basename "$repo")"
fi

if [[ "$repo" =~ ^https://gitlab.com/ ]]; then
    url="$repo"
    dir="$(basename "$repo" .git)"
elif [[ "$repo" =~ ^git@gitlab.com: ]]; then
    url="$repo"
    dir="$(basename "$repo" .git)"
else
    url="https://gitlab.com/$repo.git"
    dir="$(basename "$repo")"
fi


# If directory exists, skip cloning
if [[ -d "$dir" ]]; then
    echo "gx: directory '$dir' already exists, skipping clone"
    warn "Skip clone: $dir exists"
    exit 0
fi

# Clone repository
git clone "$url" "$dir" || ee "failed to clone $url"
echo "gx: cloned repository '$dir'"
info "Cloned repository $dir"
