#!/usr/bin/env bash
# OLS command: uedit

OLS_DIR="$HOME/.local/share/OLS"
LOG_FILE="$OLS_DIR/logs.log"
FILE="$1"

if [[ $# -eq 0 ]]; then
    echo "Usage: uedit <file>"
    exit 1
fi

echo "Opening $FILE with UEdit..."
python3 "$OLS_DIR/sbin/UEdit/main.py" "$FILE"

echo "$(date '+%Y-%m-%d %H:%M:%S') [OLS][uedit][INFO] Edited $FILE using UEdit" >> "$LOG_FILE"
