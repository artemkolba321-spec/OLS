#!/usr/bin/env bash
# OLS command: olsp

set -euo pipefail
IFS=$'\n\t'

source "$HOME/.local/share/OLS/lib/env.sh"
PLUGINS_DIR="${PLUGINS_DIR:-$OLS_DIR/plugins}"

# ===== Main =====
case "${1-}" in
    init)
        if [[ -n "${2-}" ]]; then
            PLUGIN_NAME="$2"
            [[ -d "$PLUGIN_NAME" ]] && warn "Directory '$PLUGIN_NAME' already exists"
            mkdir -p "$PLUGIN_NAME"
            cd "$PLUGIN_NAME"
        else
            PLUGIN_NAME="$(basename "$PWD")"
        fi
        # create package.json
        cat > package.json <<EOF
{
  "name": "$PLUGIN_NAME",
  "version": "0.1.0",
  "bin": false,
  "author": "$USER"
}
EOF

        SECRET="$(head /dev/urandom | tr -dc 0-9 A-Z a-z | head -c 135)"
        PUB="$(head /dev/urandom | tr -dc 0-9 | head -c 10)"

        mkdir -p keys
        touch keys/$PLUGIN_NAME.pub
        touch keys/$PLUGIN_NAME.key

        echo "$PUB" > "keys/$PLUGIN_NAME.pub"
        echo "$SECRET" > "keys/$PLUGIN_NAME.key"

        cat > .gitignore <<EOF
keys/$PLUGIN_NAME.key
EOF


        # create template plugin.lua
        cat > plugin.lua <<'EOF'
#!/usr/bin/env lua
print("Hello from plugin!")
EOF

        chmod 644 package.json plugin.lua
        mkdir -p files

        echo "Plugin '$PLUGIN_NAME' initialized successfully!"
        ;;
    keygen)
        PLUGIN_PATH="${2-}"
        if [[ -z "$PLUGIN_PATH" ]]; then
            PLUGIN_PATH="$PWD"
        fi
        [[ ! -f "package.json" ]] && ee "package.json not found"


        PLUGIN_PATH="$(realpath -m "$PLUGIN_PATH")"

        [[ ! -d "$PLUGIN_PATH" ]] && warn "Plugin not found: $PLUGIN_PATH"

        PLUGIN_NAME="$(basename "$PLUGIN_PATH")"
        KEY_DIR="$PLUGIN_PATH/keys"
        KEY_FILE="$KEY_DIR/$PLUGIN_NAME.key"
        PUB_FILE="$KEY_DIR/$PLUGIN_NAME.pub"

        mkdir -p "$KEY_DIR"

        if [[ ! -f "$PUB_FILE" ]]; then
            PUB="$(head /dev/urandom | tr -dc 0-9 | head -c 10)"
            echo "$PUB" > "$PUB_FILE"
            echo "Public key generated: $PUB_FILE"
        else
            echo "Public key exists: $PUB_FILE"
        fi

        if [[ ! -f "$KEY_FILE" ]]; then
            SECRET="$(head /dev/urandom | tr -dc 0-9 A-Z a-z | head -c 135)"            echo "$SECRET" > "$KEY_FILE"
            echo "Secret key generated: $KEY_FILE"
        else
            echo "Secret key exists: $KEY_FILE"
        fi

        info "Keys updated for plugin: $PLUGIN_PATH"
        ;;
    build)
        PLUGIN_DIR="${2-}"
        [[ -z "$PLUGIN_DIR" ]] && warn "Usage: olsp build <plugin-dir>"
        [[ ! -d "$PLUGIN_DIR" ]] && warn "Plugin directory not found"
        [[ ! -f "$PLUGIN_DIR/package.json" ]] && ee "package.json not found"

        PARENT_DIR="$(dirname "$PLUGIN_DIR")"
        PLUGIN_NAME="$(basename "$PLUGIN_DIR")"
        # Archive plugin directory with correct structure
        tar -czf "$PLUGIN_NAME.olsp" -C "$PARENT_DIR" "$PLUGIN_NAME"

        echo "Plugin built: $PLUGIN_NAME.olsp"
        info "Built plugin: $PLUGIN_NAME"
        ;;
    install)
        PACKAGE_FILE="${2-}"
        [[ -z "$PACKAGE_FILE" ]] && ee "Usage: olsp install <package.olsp>"
        [[ ! -f "$PACKAGE_FILE" ]] && ee "File not found: $PACKAGE_FILE"

        PLUGIN_NAME="$(basename "$PACKAGE_FILE" .olsp)"
        TARGET_DIR="$PLUGINS_DIR/$PLUGIN_NAME"
        BIN_DIR="$OLS_DIR/bin"

        mkdir -p "$PLUGINS_DIR" "$BIN_DIR"

        # ===== CLEAN OLD INSTALL =====
        if [[ -d "$TARGET_DIR" ]]; then
            warn "Reinstalling plugin: $PLUGIN_NAME"
            rm -rf "$TARGET_DIR"
        fi

        # ===== SAFE EXTRACT =====
        TMP_DIR="$(mktemp -d)"
        tar -xzf "$PACKAGE_FILE" -C "$TMP_DIR"

        [[ ! -d "$TMP_DIR/$PLUGIN_NAME" ]] && {
            rm -rf "$TMP_DIR"
            ee "Invalid package structure"
        }

        EXTRACTED="$TMP_DIR/$PLUGIN_NAME"

        # ===== KEY CHECK (BEFORE INSTALL) =====
        KEY_FILE="$EXTRACTED/keys/$PLUGIN_NAME.key"
        PUB_FILE="$EXTRACTED/keys/$PLUGIN_NAME.pub"

        if [[ ! -f "$KEY_FILE" || ! -f "$PUB_FILE" ]]; then
            echo "⚠️  Package is missing keys:"
            [[ ! -f "$KEY_FILE" ]] && echo "  - secret key (.key) not found"
            [[ ! -f "$PUB_FILE" ]] && echo "  - public key (.pub) not found"
            echo
            echo "This package cannot be verified."
            printf "Do you want to continue? (y/N): "
            read -r answer

            if [[ "$answer" != "y" && "$answer" != "Y" ]]; then
                echo "Installation cancelled"
                rm -rf "$TMP_DIR"
                exit 1
            fi
        else
            echo "✔ Keys found. Package marked as trusted."
        fi

        # ===== MOVE INTO SYSTEM =====
        mv "$EXTRACTED" "$TARGET_DIR"
        rm -rf "$TMP_DIR"

        # ===== VALIDATE =====
        [[ ! -f "$TARGET_DIR/package.json" ]] && ee "package.json missing"
        [[ ! -f "$TARGET_DIR/plugin.lua" ]] && ee "plugin.lua missing"

        # ===== PARSE BIN =====
        BIN_MODE="$(grep -o '"bin":[^,}]*' "$TARGET_DIR/package.json" || true)"

        if echo "$BIN_MODE" | grep -q "true"; then
            TARGET="$TARGET_DIR/plugin.lua"
            LINK="$BIN_DIR/$PLUGIN_NAME"

            chmod +x "$TARGET"

            FIRST_LINE="$(head -n1 "$TARGET" 2>/dev/null || echo "")"

            if [[ "$FIRST_LINE" != "#!"* ]]; then
                echo "⚠️  Plugin '$PLUGIN_NAME' marked as CLI (bin: true), but no shebang found."
                echo "File: $TARGET"
                echo
                echo "Example fix:"
                echo "  #!/usr/bin/env lua"
                echo

                printf "Auto-fix shebang? (Y/n): "
                read -r answer

                if [[ "$answer" == "n" || "$answer" == "N" ]]; then
                    warn "Skipping CLI registration"
                else
                    echo "Fixing shebang..."
                    sed -i '1i #!/usr/bin/env lua' "$TARGET"
                fi
            fi

            # ===== FINAL CLI LINK =====
            if head -n1 "$TARGET" | grep -q "^#!"; then
                ln -sf "$TARGET" "$LINK"
                echo "✔ CLI installed: $PLUGIN_NAME"
            else
                warn "CLI not installed (missing shebang)"
            fi
        fi

        # ===== PATH CHECK =====
        if ! echo "$PATH" | grep -q "$BIN_DIR"; then
            echo
            echo "⚠️  $BIN_DIR is not in your PATH"
            echo "Add this to your shell config:"
            echo "export PATH=\"$BIN_DIR:\$PATH\""
        fi

        echo "✔ Plugin installed: $PLUGIN_NAME"
        info "Installed plugin: $PLUGIN_NAME"
        ;;
    run)
        if [[ -n "${2-}" ]]; then
            # run installed plugin
            PLUGIN_NAME="$2"
            PLUGIN_PATH="$PLUGINS_DIR/$PLUGIN_NAME/plugin.lua"

            [[ ! -f "$PLUGIN_PATH" ]] && warn "plugin.lua not found for plugin '$PLUGIN_NAME'"
        else
            # run plugin in current directory
            PLUGIN_PATH="$PWD/plugin.lua"

            [[ ! -f "$PLUGIN_PATH" ]] && warn "plugin.lua not found in current directory"
        fi

        command -v lua >/dev/null || ee "Lua not installed"

        lua "$PLUGIN_PATH"
        ;;


    uninstall)
        PLUGIN_NAME="${2-}"
        [[ -z "$PLUGIN_NAME" ]] && warn "Usage: olsp uninstall <plugin-name>"
        TARGET_DIR="$PLUGINS_DIR/$PLUGIN_NAME"
        [[ ! -d "$TARGET_DIR" ]] && warn "Plugin not found"
        rm -rf "$TARGET_DIR"
        echo "Plugin '$PLUGIN_NAME' removed"
        info "Uninstalled plugin: $PLUGIN_NAME"
        ;;
    list)
        echo "Installed plugins:"
        ls -1 "$PLUGINS_DIR"
        ;;

    *)
        info "Unknown command: $1"
        ;;
esac
